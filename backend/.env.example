OPENAI_API_KEY=sk-proj-your-key-here
FLIGHTAPI_API_KEY=your-aviationstack-key-here
DATABASE_URL=postgresql://postgres:postgres@db:5432/travel_agent
CHROMA_PERSIST_DIRECTORY=./chroma_db
OPENAI_MODEL=gpt-4o
DEBUG=false
LOG_LEVEL=INFO
BASE_URL=http://localhost:8000

# Orquestador de PRE-VENTA con tool calling (default: true — legacy deshabilitado)
# USE_TOOL_CALLING_AGENT=true

# Orquestador de POST-VENTA con tool calling (default: true — legacy deshabilitado)
# USE_TOOL_CALLING_POSTSALE=true

# PoC: orquestador de pre-venta sobre OpenAI Agents SDK (default: false)
# USE_AGENTS_SDK_PREVENTA=false

# PoC: orquestador de post-venta sobre OpenAI Agents SDK (default: false)
# Tiene prioridad sobre USE_TOOL_CALLING_POSTSALE cuando está activo.
# USE_AGENTS_SDK_POSTVENTA=false

# PoC: ruteo pre/post-venta mediante triage agent con handoffs del SDK (default: false)
# Una sola pasada del SDK reemplaza las 2 clasificaciones caseras (casual + post-venta).
# Los cortocircuitos duros (código de reserva, sesión activa) siguen corriendo antes.
# USE_AGENTS_SDK_TRIAGE=false
